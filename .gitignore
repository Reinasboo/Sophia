# ─────────────────────────────────────────────────────
# Sophia — .gitignore
# ─────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build outputs
dist/
build/
out/
.next/
apps/frontend/.next/
apps/frontend/out/

# Coverage and test artifacts
coverage/
.nyc_output/
*.lcov

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE and tooling
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.code-workspace
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Runtime and cache
*.pid
*.seed
*.tmp
tmp/
.cache/
.turbo/
.eslintcache
.parcel-cache/
*.tsbuildinfo

# Persistence (contains encrypted wallet key material and operational data)
data/
.cli-wallet.json

# Security-sensitive files — never commit
.envrc
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_ed25519

# Package manager lock files (keep npm only)
yarn.lock
pnpm-lock.yaml

# Miscellaneous
*.tgz
.npmrc

.vercel
.env*.local
