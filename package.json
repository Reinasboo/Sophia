{
  "name": "agentic-wallet-system",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade autonomous AI wallet orchestration for Solana with BYOA integration and security-first governance.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Reinasboo/Sophia.git"
  },
  "homepage": "https://github.com/Reinasboo/Sophia",
  "bugs": {
    "url": "https://github.com/Reinasboo/Sophia/issues",
    "email": "security@sophia.dev"
  },
  "keywords": [
    "solana",
    "wallet",
    "ai-agents",
    "autonomous",
    "agent-orchestration",
    "web3",
    "blockchain",
    "defi",
    "typescript",
    "encryption",
    "byoa",
    "intent-based"
  ],
  "author": "Reinasboo (https://github.com/Reinasboo)",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node --disable-warning=DEP0040 --require tsx/cjs --require ./src/preload.ts --import tsx src/index.ts",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build": "tsc && cd apps/frontend && npm run build",
    "start": "node dist/index.js",
    "start:server": "node dist/index.js",
    "test": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.91.0",
    "bs58": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "fastestsmallesttextencoderdecoder": "^1.0.22",
    "tweetnacl": "^1.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
