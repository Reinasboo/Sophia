# ─────────────────────────────────────────────────────────────
# Sophia (Autonomous Wallet System) — Environment Configuration
# Copy this file to .env and customize the values.
#
#   cp .env.example .env
#
# ⚠ SECURITY: Never commit .env to version control.
#   This file (.env.example) contains safe defaults only.
# ─────────────────────────────────────────────────────────────

# ── Solana ──────────────────────────────────────────────────
# Primary RPC endpoint for Solana mainnet
SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/3fYPQ8ilgt2wNYVp0nEzu

# Multi-RPC failover (comma-separated, primary first)
# Format: https://primary-endpoint.com,https://fallback-endpoint.com
# This enables automatic failover if primary endpoint returns 429/503 errors
SOLANA_RPC_URLS=https://solana-mainnet.g.alchemy.com/v2/3fYPQ8ilgt2wNYVp0nEzu,https://solana-rpc.publicnode.com

# Network: mainnet (production), devnet (testing)
SOLANA_NETWORK=mainnet

# ── Server ──────────────────────────────────────────────────
PORT=3001
WS_PORT=3002

# ── Security ────────────────────────────────────────────────
# ⚠ REQUIRED: Replace these with strong, unique values before running.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_SECRET=replace-me-with-32-hex-chars-minimum
ADMIN_API_KEY=replace-me-with-a-strong-admin-key

# ── CORS (comma-separated origins, leave empty for default) ─
CORS_ORIGINS=

# ── Agents ──────────────────────────────────────────────────
MAX_AGENTS=20
AGENT_LOOP_INTERVAL_MS=5000

# ── Privy Authentication ────────────────────────────────────
# Get your Privy App ID and Secret Key from https://privy.io/dashboard
# Frontend only (NEXT_PUBLIC_ prefix makes it accessible to browser)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here
# Backend only (Secret Key - keep private!)
PRIVY_APP_ID=your-privy-app-id-here
PRIVY_SECRET_KEY=your-privy-secret-key-here

# ── Transactions ────────────────────────────────────────────
MAX_RETRIES=3
CONFIRMATION_TIMEOUT_MS=30000

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
