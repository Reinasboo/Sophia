# ─────────────────────────────────────────────────────────────
# Agentic Wallet System — Environment Configuration
# Copy this file to .env and customise the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Solana ──────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# ── Server ──────────────────────────────────────────────────
PORT=3001
WS_PORT=3002

# ── Security ────────────────────────────────────────────────
# IMPORTANT: Replace these with strong, unique values.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KEY_ENCRYPTION_SECRET=replace-me-with-32-hex-chars-minimum
ADMIN_API_KEY=replace-me-with-a-strong-admin-key

# ── CORS (comma-separated origins, leave empty for default) ─
CORS_ORIGINS=

# ── Agents ──────────────────────────────────────────────────
MAX_AGENTS=20
AGENT_LOOP_INTERVAL_MS=5000

# ── Transactions ────────────────────────────────────────────
MAX_RETRIES=3
CONFIRMATION_TIMEOUT_MS=30000

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
